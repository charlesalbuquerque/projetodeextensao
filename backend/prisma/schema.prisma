generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Animal {
  id          Int     @id @default(autoincrement())
  nome        String
  especie     String
  status      String
  localizacao String
  descricao   String
  isApproved  Boolean @default(false)
  adotanteId  Int?

  // RELAÇÕES OPOSTAS (O que faltava)
  adotante     User?                 @relation("Adocoes", fields: [adotanteId], references: [id])
  donations    Donation[]
  candidaturas AdoptionApplication[]
}

model AdoptionApplication {
  id       Int    @id @default(autoincrement())
  animalId Int
  userId   Int
  info     String
  status   String @default("PENDENTE")

  animal Animal @relation(fields: [animalId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}

model Supplier {
  id      Int     @id @default(autoincrement())
  nome    String
  contato String
  tipo    String
  servico String?
}

model Donation {
  id       Int      @id @default(autoincrement())
  valor    Float
  doador   String
  animalId Int?
  animal   Animal?  @relation(fields: [animalId], references: [id])
  data     DateTime @default(now())
}

model User {
  id    Int    @id @default(autoincrement())
  nome  String
  email String @unique
  senha String
  role  String @default("USER")

  // RELAÇÕES OPOSTAS (O que faltava)
  animais      Animal[]              @relation("Adocoes")
  applications AdoptionApplication[]
}

model Expense {
  id        Int      @id @default(autoincrement())
  descricao String
  valor     Float
  categoria String
  data      DateTime @default(now())
}
